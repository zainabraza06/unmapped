# ============================================================
# Unmapped Node API — environment variables
# Copy this file to .env and fill in your values.
# The API runs fully offline without any of these set.
# ============================================================

# --- LLM Skill Extractor (OpenRouter) --------------------------------------
# When OPENROUTER_API_KEY is set the API uses an LLM to extract skills and
# tasks from free-text input. When unset it falls back to deterministic
# heuristic extraction — no LLM call is made and no external network access
# occurs.
#
# Get a free key at https://openrouter.ai/

OPENROUTER_API_KEY=

# Model slug. Free-tier example. Any OpenRouter-supported model works.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# LLM request timeout in milliseconds. Exceeded requests auto-fallback to
# heuristic extraction.
LLM_TIMEOUT_MS=8000

# --- Server ----------------------------------------------------------------
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
NODE_ENV=development
